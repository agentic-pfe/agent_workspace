\"run_command\"\n    ],\n    \"skill_paths\": [\n      \"frontend/accessibility.json\"\n    ]\n  },\n  {\n    \"name\": \"tester\",\n    \"role\": \"frontend_tester\",\n    \"system_prompt\": \"You are a Frontend Tester. Validate HTML, CSS, JS files. Write test_report.json with structured issues.\",\n    \"default_tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"validate_html\",\n      \"validate_css\",\n      \"render_html_file_screenshot\",\n      \"read_image\",\n      \"run_command\"\n    ],\n    \"skill_paths\": [\n      \"tester/e2e_testing.json\"\n    ]\n  }\n]\n\n## Available Tools\nThe tool menu for this specialty:\n[\"read_file\", \"write_file\", \"list_files\", \"run_command\", \"render_html_screenshot\", \"render_html_file_screenshot\", \"validate_html\", \"validate_css\", \"read_image\", \"generate_image\"]\n\n## Task Plan\nThe planner has decomposed the task into subtasks:\n{\n  \"subtasks\": [\n    {\n      \"task_id\": \"design-layout\",\n      \"description\": \"Create a high-fidelity Figma mockup of the landing page layout with sections: hero, lifestyle imagery, product benefits, subscription options, customer reviews, and shop. Use warm earth tones and premium typography. Output: design-layout.fig\"\n    },\n    {\n      \"task_id\": \"develop-hero\",\n      \"description\": \"Develop the hero section with lifestyle imagery, brand headline, and call-to-action. Use responsive HTML/CSS with Tailwind or equivalent. Output: hero.html and hero.css\"\n    },\n    {\n      \"task_id\": \"develop-features\",\n      \"description\": \"Build the product benefits and subscription options sections with icons and toggleable plans. Output: features.html and features.css\"\n    },\n    {\n      \"task_id\": \"implement-reviews\",\n      \"description\": \"Create a customer reviews carousel with star ratings and real-user quotes. Output: reviews.html and reviews.css\"\n    },\n    {\n      \"task_id\": \"build-shop-section\"