\"run_command\"\n    ],\n    \"skill_paths\": [\n      \"frontend/accessibility.json\"\n    ]\n  },\n  {\n    \"name\": \"tester\",\n    \"role\": \"frontend_tester\",\n    \"system_prompt\": \"You are a Frontend Tester. Validate HTML, CSS, JS files. Write test_report.json with structured issues.\",\n    \"default_tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"validate_html\",\n      \"validate_css\",\n      \"render_html_file_screenshot\",\n      \"read_image\",\n      \"run_command\"\n    ],\n    \"skill_paths\": [\n      \"tester/e2e_testing.json\"\n    ]\n  }\n]\n\n## Available Tools\nThe tool menu for this specialty:\n[\"read_file\", \"write_file\", \"list_files\", \"run_command\", \"render_html_screenshot\", \"render_html_file_screenshot\", \"validate_html\", \"validate_css\", \"read_image\", \"generate_image\"]\n\n## Task Plan\nThe planner has decomposed the task into subtasks:\n{\n  \"subtasks\": [\n    {\n      \"task_id\": \"research\",\n      \"description\": \"Gather information on typical components of a backend developer portfolio, including skills, projects, and contact info to feature on the landing page\"\n    },\n    {\n      \"task_id\": \"design-ui\",\n      \"description\": \"Create a simple, clean UI design mockup in Figma or as a static HTML/CSS file named 'landing-page-design.html' with sections: Hero, Skills, Projects, and Contact\"\n    },\n    {\n      \"task_id\": \"develop-page\",\n      \"description\": \"Implement the landing page in HTML, CSS, and minimal JavaScript; output files: index.html, styles.css, script.js\"\n    },\n    {\n      \"task_id\": \"test-responsiveness\",\n      \"description\": \"Test page responsiveness across devices and validate HTML/CSS; provide a brief report in 'test-report.txt'\"\n    }\n  ]\n}\n\n## Your Job\nFor EACH subtask in the plan:\n1. Pick the BEST matching template from the available templates above\n2. Optionally EDIT the system_prompt to add task-specific