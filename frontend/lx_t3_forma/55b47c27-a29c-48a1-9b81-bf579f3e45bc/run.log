Keep it simple: 1-2 workers is ideal\n- Output ONLY valid JSON — no markdown fences\n\n## Output Format\n{\n  \"workers\": [\n    {\n      \"worker_name\": \"task_id_from_plan\",\n      \"system_prompt\": \"Full custom system instructions pushing toward end-to-end completion\",\n      \"tool_names\": [\"tool1\", \"tool2\", \"...\"]\n    }\n  ]\n}\n\n## Reference Templates (suggestions only - pick what makes sense)\n[\n  {\n    \"name\": \"ux\",\n    \"tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"generate_image\"\n    ]\n  },\n  {\n    \"name\": \"html\",\n    \"tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"validate_html\",\n      \"render_html_file_screenshot\",\n      \"generate_image\",\n      \"run_command\"\n    ]\n  },\n  {\n    \"name\": \"css\",\n    \"tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"validate_css\",\n      \"run_command\"\n    ]\n  },\n  {\n    \"name\": \"js\",\n    \"tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"run_command\"\n    ]\n  },\n  {\n    \"name\": \"tester\",\n    \"tools\": [\n      \"read_file\",\n      \"write_file\",\n      \"list_files\",\n      \"validate_html\",\n      \"validate_css\",\n      \"render_html_file_screenshot\",\n      \"read_image\",\n      \"run_command\"\n    ]\n  }\n]", "meta": {}}
