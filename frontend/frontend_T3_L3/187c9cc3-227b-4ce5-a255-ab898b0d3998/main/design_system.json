{
    "design_tokens": {
        "palette": {
            "primary": {"hex": "#2563EB", "role": "primary brand color, headers, primary actions"},
            "secondary": {"hex": "#7C3AED", "role": "secondary highlights, decorative elements"},
            "accent": {"hex": "#EC4899", "role": "call-to-action, urgent interactions"},
            "neutral": {
                "50": {"hex": "#F8FAFC", "role": "lightest background"},
                "100": {"hex": "#F1F5F9", "role": "light backgrounds, section dividers"},
                "500": {"hex": "#64748B", "role": "body text, secondary text"},
                "900": {"hex": "#0F172A", "role": "darkest text, headings"}
            }
        },
        "typography": {
            "heading": "Inter",
            "body": "Open Sans",
            "scale": {
                "h1": {"size": "3.5rem", "weight": 700, "lineHeight": 1.2},
                "h2": {"size": "2.5rem", "weight": 700, "lineHeight": 1.3},
                "h3": {"size": "1.75rem", "weight": 600, "lineHeight": 1.4},
                "body": {"size": "1rem", "weight": 400, "lineHeight": 1.6},
                "small": {"size": "0.875rem", "weight": 400, "lineHeight": 1.5}
            }
        },
        "spacing": {
            "xs": "0.5rem",
            "sm": "1rem", 
            "md": "1.5rem",
            "lg": "2rem",
            "xl": "3rem",
            "xxl": "4rem"
        },
        "component_styles": {
            "buttons": {
                "primary": {
                    "backgroundColor": "#2563EB",
                    "color": "#FFFFFF", 
                    "padding": "0.75rem 1.5rem",
                    "borderRadius": "0.5rem",
                    "fontWeight": 600,
                    "hover": {
                        "backgroundColor": "#1D4ED8"
                    }
                },
                "secondary": {
                    "backgroundColor": "transparent",
                    "color": "#2563EB",
                    "border": "2px solid #2563EB",
                    "padding": "0.75rem 1.5rem",
                    "borderRadius": "0.5rem",
                    "fontWeight": 600,
                    "hover": {
                        "backgroundColor": "rgba(37, 99, 235, 0.1)"
                    }
                }
            },
            "navigation": {
                "backgroundColor": "#FFFFFF",
                "height": "4rem",
                "linkColor": "#0F172A",
                "linkHoverColor": "#2563EB",
                "mobileBreakpoint": "768px"
            },
            "cards": {
                "backgroundColor": "#FFFFFF",
                "borderRadius": "0.75rem",
                "boxShadow": "0 4px 6px rgba(0,0,0,0.1)",
                "padding": "1.5rem",
                "hover": {
                    "boxShadow": "0 10px 15px rgba(0,0,0,0.15)"
                }
            }
        },
        "breakpoints": {
            "mobile": "375px",
            "tablet": "768px", 
            "desktop": "1024px",
            "large": "1440px"
        }
    },
    "brand_guidelines": {
        "name": "Forma Studio",
        "tagline": "Crafting Digital Experiences",
        "mood": "Modern, Minimalist, Creative",
        "voice": "Professional yet approachable, innovative and precise"
    }
